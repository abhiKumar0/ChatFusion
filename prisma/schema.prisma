// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================================
//          ENUMS
// =================================

enum ConversationType {
  ONE_TO_ONE
  GROUP
}

enum ParticipantRole {
  ADMIN
  MEMBER
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// =================================
//          MODELS
// =================================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  fullName  String?
  avatar    String?
  password  String // Hashed password for login
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isOnline  Boolean  @default(false)

  // --- Fields for E2EE ---
  publicKey           String? // User's public key (sharable)
  encryptedPrivateKey String? // Private key, encrypted with user's password
  // salt                String? // Salt used for deriving key from password
  // keyNonce            String? // Nonce used for encrypting the private key

  // --- Relations ---
  messagesSent           Message[]                 @relation("SentMessages")
  conversations          ConversationParticipant[]
  sentFriendRequests     FriendRequest[]           @relation("SentRequests")
  receivedFriendRequests FriendRequest[]           @relation("ReceivedRequests")
}

model Conversation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  name      String? //Group name
  type      ConversationType @default(ONE_TO_ONE)
  avatar    String? // Group avatar

  // --- Relations ---
  messages     Message[]
  participants ConversationParticipant[]
}

// Join table to manage users in conversations and their roles
model ConversationParticipant {
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  role           ParticipantRole @default(MEMBER)

  @@id([userId, conversationId])
}

model Message {
  id        String   @id @default(cuid())
  content   String // Encrypted message content
  nonce     String // Nonce used for E2EE decryption
  media     String? // Encrypted media URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("sent")

  // --- Relations ---
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  // --- Fields for Threaded Messages (Re-added) ---
  parentMessage   Message?  @relation("Replies", fields: [parentMessageId], references: [id])
  parentMessageId String?
  replies         Message[] @relation("Replies")
}

model FriendRequest {
  id        String              @id @default(cuid())
  status    FriendRequestStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // --- Relations ---
  sender     User   @relation("SentRequests", fields: [senderId], references: [id])
  senderId   String
  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id])
  receiverId String

  @@unique([senderId, receiverId]) // Ensures a user can only send one request to another
}
